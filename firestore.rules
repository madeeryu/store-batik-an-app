rules_version = '2';

// ============================================================
// Firestore Security Rules — Batik AN (project: store-batik-an)
// GABUNGAN: rules lama + pembatasan untuk akun "pelanggan".
// ------------------------------------------------------------
// Perilaku:
//  - Akun lama (owner/karyawan, atau akun login apa pun yang BUKAN pelanggan):
//    tetap punya akses penuh ke semua koleksi — SAMA PERSIS seperti rules lama
//    (catch-all `request.auth != null`). Tidak ada yang berubah untuk staf.
//  - Akun dengan role 'pelanggan': HANYA boleh BACA stok, produk, dan data
//    miliknya sendiri (pelanggan/transaksi/pembayaran). Tidak bisa menulis,
//    tidak bisa melihat data pelanggan lain / data internal.
//
// Cara pasang: Firebase Console → Firestore Database → Rules → tempel → Publish.
// ============================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // ---------- Helper ----------
    function isSignedIn() { return request.auth != null; }

    // True hanya jika dok users ada DAN role-nya 'pelanggan'.
    // Jika dok users tidak ada / tanpa role → dianggap BUKAN pelanggan,
    // sehingga akun lama tetap dapat akses penuh (mempertahankan rules lama).
    function isPelanggan() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'pelanggan';
    }
    function myPelangganId() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.pelanggan_id;
    }

    // ---------- USERS (dari rules lama) ----------
    // Setiap user boleh baca dokumennya sendiri (dipakai saat login pelanggan
    // untuk membaca role & pelanggan_id). Tulis users hanya oleh owner.
    match /users/{uid} {
      allow read: if isSignedIn() && request.auth.uid == uid;
      allow write: if isSignedIn()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'owner';
    }

    // ---------- Izin BACA untuk pelanggan (read-only) ----------
    match /stok/{id}   { allow read: if isPelanggan(); }
    match /produk/{id} { allow read: if isPelanggan(); }

    match /pelanggan/{id} {
      allow read: if isPelanggan() && id == myPelangganId();
    }
    // Wajib query pakai where('pelanggan_id','==', <id-nya>) agar lolos rules.
    match /transaksi/{id} {
      allow read: if isPelanggan() && resource.data.pelanggan_id == myPelangganId();
    }
    match /pembayaran/{id} {
      allow read: if isPelanggan() && resource.data.pelanggan_id == myPelangganId();
    }

    // ---------- Catch-all (dari rules lama, dipersempit) ----------
    // Semua user login KECUALI pelanggan → akses penuh, persis rules lama.
    // Pelanggan dikecualikan agar pembatasan baca/tulis di atas berlaku.
    match /{document=**} {
      allow read, write: if isSignedIn() && !isPelanggan();
    }
  }
}
